# Application
APP_NAME=TalentConnect Matching Algorithm
ENVIRONMENT=development

# Copy this file to .env and fill in your values.

# Embedding provider:
# - gemini: preferred provider for this sprint
# - local: fallback path using sentence-transformers locally
EMBEDDING_PROVIDER=gemini

# Required only when EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Required only when EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Matching configuration
SHORTLIST_SIZE=20

# Training / validation
XGBOOST_RANDOM_SEED=42
MODEL_DIR=models
RANKER_MODEL_PATH=
MODEL_MIN_NDCG_IMPROVEMENT=0.05

# Iteration / retraining
STALENESS_CAP_DAYS=30
VOLUME_THRESHOLD_BASE=25

# API / logging
REQUIRE_AUTH=false
INTERNAL_API_TOKEN=change_me_for_demo
LOG_LEVEL=INFO
